{
  "name": "nexus-store",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "predev": "node scripts/check-node.mjs",
    "prebuild": "node scripts/check-node.mjs",
    "prepreview": "node scripts/check-node.mjs",
    "dev": "concurrently -n api,web -c cyan,green \"npm run server\" \"npm run client\"",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File scripts/free-ports.ps1 && npm run dev",
    "client": "vite",
    "server": "node server/index.js",
    "build": "node scripts/build.mjs",
    "start": "node server/index.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  }
}
